<div id={song._id}
  class="bg-white/50 rounded-3xl p-5 flex gap-6 items-center hover:bg-white transition shadow-sm"
>
  <div class="rounded-2xl w-14 h-14 overflow-hidden bg-gray-800 flex-shrink-0">
    <img src={song.album.image.url} class="w-full h-full object-cover" />
  </div>
  <div class="flex-1">
    <p class="font-bold text-lg text-gray-700">{song.title}</p>
    <p class="text-gray-400 text-sm">{song.author.name}</p>
  </div>
  <p class="text-gray-400 font-bold">3:52</p>
</div>

<script define:vars={{ song }}>
  const container = document.getElementById(song._id);
  // const player = document.getElementById("audioPlayer");

  container.addEventListener("click", () => {
    // player.src = song.audio.url; //
    // player.play();

    const event = new CustomEvent("playSong", {
      detail: { song },
    });

    window.dispatchEvent(event);
  });
</script>
